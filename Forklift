<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forklift Blind Zone 3D Simulator</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');
  
  * { margin:0; padding:0; box-sizing:border-box; }
  
  body {
    background: #0a0d0f;
    color: #e0e8ef;
    font-family: 'Share Tech Mono', monospace;
    overflow: hidden;
    height: 100vh;
    width: 100vw;
  }

  #canvas-container {
    position: fixed; inset: 0;
  }

  #hud {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 10;
    pointer-events: none;
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  #title-block { pointer-events: none; }

  #title-block h1 {
    font-family: 'Orbitron', sans-serif;
    font-size: 15px;
    font-weight: 900;
    color: #ff6b00;
    letter-spacing: 2px;
    text-shadow: 0 0 20px #ff6b0066;
  }

  #title-block p {
    font-size: 10px;
    color: #7a9ab0;
    margin-top: 2px;
    letter-spacing: 1px;
  }

  #stats-panel {
    pointer-events: none;
    display: flex;
    gap: 8px;
  }

  .stat-box {
    background: rgba(10,20,30,0.85);
    border: 1px solid #1e3a4a;
    border-top: 2px solid #ff6b00;
    padding: 8px 12px;
    min-width: 100px;
  }

  .stat-label {
    font-size: 8px;
    color: #7a9ab0;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .stat-value {
    font-family: 'Orbitron', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #ff6b00;
    margin-top: 2px;
  }

  .stat-value.safe { color: #00ff88; }
  .stat-value.danger { color: #ff2244; animation: blink 0.8s infinite; }

  @keyframes blink {
    0%,100% { opacity:1; } 50% { opacity:0.3; }
  }

  #controls {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .ctrl-btn {
    background: rgba(10,20,30,0.9);
    border: 1px solid #2a4a5a;
    color: #c0d8e8;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    padding: 8px 14px;
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.15s;
    text-transform: uppercase;
  }

  .ctrl-btn:hover {
    background: rgba(255,107,0,0.2);
    border-color: #ff6b00;
    color: #ff6b00;
  }

  .ctrl-btn.active {
    background: rgba(255,107,0,0.3);
    border-color: #ff6b00;
    color: #ff6b00;
    box-shadow: 0 0 10px #ff6b0044;
  }

  #legend {
    position: fixed;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(8,16,22,0.9);
    border: 1px solid #1e3a4a;
    border-left: 3px solid #ff6b00;
    padding: 14px 16px;
    pointer-events: none;
  }

  #legend h3 {
    font-family: 'Orbitron', sans-serif;
    font-size: 9px;
    color: #ff6b00;
    letter-spacing: 2px;
    margin-bottom: 10px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 7px;
    font-size: 10px;
    color: #a0c0d0;
  }

  .legend-dot {
    width: 12px; height: 12px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  #alert {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 20;
    background: rgba(255,20,50,0.15);
    border: 2px solid #ff2244;
    padding: 12px 28px;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    backdrop-filter: blur(4px);
  }

  #alert.show { opacity: 1; }

  #alert .alert-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 18px;
    color: #ff2244;
    font-weight: 900;
    letter-spacing: 3px;
  }

  #alert .alert-sub {
    font-size: 11px;
    color: #ffaaaa;
    margin-top: 4px;
    letter-spacing: 1px;
  }

  #info-panel {
    position: fixed;
    left: 20px;
    bottom: 80px;
    z-index: 10;
    background: rgba(8,16,22,0.88);
    border: 1px solid #1e3a4a;
    border-left: 3px solid #ff6b00;
    padding: 12px 14px;
    max-width: 220px;
    pointer-events: none;
  }

  #info-panel h3 {
    font-family: 'Orbitron', sans-serif;
    font-size: 9px;
    color: #ff6b00;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .info-row {
    font-size: 9px;
    color: #8ab0c0;
    margin-bottom: 4px;
    line-height: 1.5;
  }

  .info-row span { color: #e0e8ef; }

  #person-ctrl {
    position: fixed;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(8,16,22,0.88);
    border: 1px solid #1e3a4a;
    border-left: 3px solid #4a9aff;
    padding: 14px 12px;
    width: 150px;
  }

  #person-ctrl h3 {
    font-family: 'Orbitron', sans-serif;
    font-size: 8px;
    color: #4a9aff;
    letter-spacing: 2px;
    margin-bottom: 10px;
  }

  .slider-row { margin-bottom: 12px; }

  .slider-row label {
    font-size: 9px;
    color: #8ab0c0;
    display: block;
    margin-bottom: 4px;
  }

  input[type=range] {
    width: 100%;
    accent-color: #ff6b00;
    height: 4px;
  }

  .slider-val {
    font-size: 9px;
    color: #ff6b00;
    text-align: right;
    margin-top: 2px;
  }
</style>
</head>
<body>

<div id="canvas-container"></div>

<!-- HUD -->
<div id="hud">
  <div id="title-block">
    <h1>⚠ FORKLIFT BLIND ZONE 3D SIMULATOR</h1>
    <p>Occupational Safety Visualization · OSHA 29 CFR 1910.178 / ANSI B56.1 Standard</p>
  </div>
  <div id="stats-panel">
    <div class="stat-box">
      <div class="stat-label">Visible Zone</div>
      <div class="stat-value safe" id="vis-pct">73%</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">Blind Zone</div>
      <div class="stat-value" id="blind-pct" style="color:#ff6b00">27%</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">Pedestrian</div>
      <div class="stat-value safe" id="person-status">SAFE</div>
    </div>
  </div>
</div>

<!-- Left panel: person controls -->
<div id="person-ctrl">
  <h3>👤 PEDESTRIAN</h3>
  <div class="slider-row">
    <label>Fwd / Rear (X)</label>
    <input type="range" id="px" min="-6" max="6" value="3" step="0.1">
    <div class="slider-val" id="px-val">3.0m</div>
  </div>
  <div class="slider-row">
    <label>Left / Right (Z)</label>
    <input type="range" id="pz" min="-6" max="6" value="2" step="0.1">
    <div class="slider-val" id="pz-val">2.0m</div>
  </div>
  <div class="slider-row">
    <label>Fork Height</label>
    <input type="range" id="forkH" min="0" max="3" value="0.3" step="0.1">
    <div class="slider-val" id="forkH-val">0.3m</div>
  </div>
</div>

<!-- Legend -->
<div id="legend">
  <h3>● LEGEND</h3>
  <div class="legend-item">
    <div class="legend-dot" style="background:#ff220088;border:1px solid #ff2244"></div>
    <span>Front Mast Blind Zone</span>
  </div>
  <div class="legend-item">
    <div class="legend-dot" style="background:#ff660055;border:1px solid #ff6600"></div>
    <span>Side Pillar Blind Zone</span>
  </div>
  <div class="legend-item">
    <div class="legend-dot" style="background:#ffcc0044;border:1px solid #ffcc00"></div>
    <span>Rear Counterweight Zone</span>
  </div>
  <div class="legend-item">
    <div class="legend-dot" style="background:#ff440066;border:1px solid #ff4400"></div>
    <span>Load Obstruction Zone</span>
  </div>
  <div class="legend-item">
    <div class="legend-dot" style="background:#00aaff22;border:1px solid #00aaff"></div>
    <span>Driver Visible Field</span>
  </div>
  <div class="legend-item">
    <div class="legend-dot" style="background:#00ff8844;border:1px solid #00ff88"></div>
    <span>Pedestrian (Safe)</span>
  </div>
  <div class="legend-item">
    <div class="legend-dot" style="background:#ff224444;border:1px solid #ff2244"></div>
    <span>Pedestrian (Danger!)</span>
  </div>
</div>

<!-- Controls -->
<div id="controls">
  <button class="ctrl-btn active" id="btn-orbit" onclick="setView('orbit')">🔄 FREE ROTATE</button>
  <button class="ctrl-btn" id="btn-driver" onclick="setView('driver')">🚗 DRIVER POV</button>
  <button class="ctrl-btn" id="btn-top" onclick="setView('top')">🔼 TOP VIEW</button>
  <button class="ctrl-btn" id="btn-side" onclick="setView('side')">◀ SIDE VIEW</button>
  <button class="ctrl-btn" id="btn-blind" onclick="toggleBlind()">👁 BLIND ZONES</button>
  <button class="ctrl-btn" id="btn-load" onclick="toggleLoad()">📦 ADD LOAD</button>
  <button class="ctrl-btn" id="btn-anim" onclick="toggleAnim()">▶ WALK PEDESTRIAN</button>
</div>

<!-- Alert -->
<div id="alert">
  <div class="alert-title">⚠ HAZARD DETECTED</div>
  <div class="alert-sub">Pedestrian entered blind zone — OPERATOR CANNOT SEE</div>
</div>

<!-- Info panel -->
<div id="info-panel">
  <h3>📊 BLIND ZONE DATA</h3>
  <div class="info-row">Front Mast: <span>±35° / 1.2m width</span></div>
  <div class="info-row">Rear Counterweight: <span>±20° restriction</span></div>
  <div class="info-row">Side A-Pillar: <span>13–18° each</span></div>
  <div class="info-row">Load obstruction: <span>up to +40%</span></div>
  <div class="info-row">View Mode: <span id="view-mode-txt">Free Rotate</span></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// =============================================
// SCENE SETUP
// =============================================
const container = document.getElementById('canvas-container');
const W = window.innerWidth, H = window.innerHeight;

const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setSize(W, H);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 0.9;
container.appendChild(renderer.domElement);

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x050810);
scene.fog = new THREE.FogExp2(0x050810, 0.03);

const camera = new THREE.PerspectiveCamera(60, W/H, 0.1, 200);
camera.position.set(8, 6, 10);
camera.lookAt(0, 1, 0);

let isDragging = false, lastMX = 0, lastMY = 0;
let orbitTheta = 0.6, orbitPhi = 0.45, orbitR = 14;
let orbitTarget = new THREE.Vector3(0, 1, 0);
let currentView = 'orbit';
let targetCamPos = new THREE.Vector3();
let targetCamLook = new THREE.Vector3();
let lerpingCam = false;

// =============================================
// LIGHTING
// =============================================
scene.add(new THREE.AmbientLight(0x1a2a3a, 0.6));

const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
dirLight.position.set(8, 12, 5);
dirLight.castShadow = true;
dirLight.shadow.mapSize.width = 2048;
dirLight.shadow.mapSize.height = 2048;
dirLight.shadow.camera.near = 0.1;
dirLight.shadow.camera.far = 60;
dirLight.shadow.camera.left = -15;
dirLight.shadow.camera.right = 15;
dirLight.shadow.camera.top = 15;
dirLight.shadow.camera.bottom = -15;
scene.add(dirLight);

const warningLight = new THREE.PointLight(0xff6600, 0.5, 10);
warningLight.position.set(0, 4, 0);
scene.add(warningLight);

// =============================================
// FLOOR (warehouse)
// =============================================
const floor = new THREE.Mesh(
  new THREE.PlaneGeometry(40, 40, 40, 40),
  new THREE.MeshStandardMaterial({ color: 0x1a2428, roughness: 0.9, metalness: 0.1 })
);
floor.rotation.x = -Math.PI / 2;
floor.receiveShadow = true;
scene.add(floor);

const gridHelper = new THREE.GridHelper(40, 40, 0x2a4a5a, 0x1a3040);
gridHelper.position.y = 0.01;
scene.add(gridHelper);

// Safety floor stripes
const stripeMat0 = new THREE.MeshStandardMaterial({ color: 0xffcc00, roughness: 1 });
for (let i = -3; i <= 3; i++) {
  const stripe = new THREE.Mesh(new THREE.PlaneGeometry(12, 0.15), stripeMat0);
  stripe.rotation.x = -Math.PI / 2;
  stripe.position.set(i * 1.5, 0.02, 5);
  scene.add(stripe);
}

// =============================================
// FORKLIFT MODEL
// =============================================
const forkliftGroup = new THREE.Group();
scene.add(forkliftGroup);

const bodyMat   = new THREE.MeshStandardMaterial({ color: 0xf5a500, roughness: 0.4, metalness: 0.5 });
const darkMat   = new THREE.MeshStandardMaterial({ color: 0x1a2028, roughness: 0.8, metalness: 0.3 });
const mastMat   = new THREE.MeshStandardMaterial({ color: 0x4a5566, roughness: 0.4, metalness: 0.7 });
const cwMat     = new THREE.MeshStandardMaterial({ color: 0x222a32, roughness: 0.7, metalness: 0.5 });
const rimMat    = new THREE.MeshStandardMaterial({ color: 0x556677, roughness: 0.3, metalness: 0.8 });
const wheelMat  = new THREE.MeshStandardMaterial({ color: 0x111518, roughness: 0.9, metalness: 0.1 });
const seatMat   = new THREE.MeshStandardMaterial({ color: 0x333a44, roughness: 0.8 });
const cylMat    = new THREE.MeshStandardMaterial({ color: 0x8a9ab0, roughness: 0.2, metalness: 0.9 });
const forkMat   = new THREE.MeshStandardMaterial({ color: 0x5a6575, roughness: 0.3, metalness: 0.8 });
const carMat    = new THREE.MeshStandardMaterial({ color: 0x3a4555, roughness: 0.5, metalness: 0.6 });
const lightMat  = new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0xffffff, emissiveIntensity: 0.8 });
const strobeMat = new THREE.MeshStandardMaterial({ color: 0xff6600, emissive: 0xff6600, emissiveIntensity: 1 });

function box(w,h,d,mat,px,py,pz,rx=0,ry=0,rz=0) {
  const m = new THREE.Mesh(new THREE.BoxGeometry(w,h,d), mat);
  m.position.set(px,py,pz);
  m.rotation.set(rx,ry,rz);
  m.castShadow = true; m.receiveShadow = true;
  forkliftGroup.add(m);
  return m;
}

// Body
box(2.0, 0.9, 3.2, bodyMat,  0, 0.75, -0.2);
box(2.2, 0.35,3.5, darkMat,  0, 0.18, -0.2);
box(1.8, 0.5, 1.2, bodyMat,  0, 1.35, -1.0);
box(2.0, 1.1, 0.85, cwMat,   0, 0.85, -1.85);  // counterweight
box(1.7, 0.1, 1.2, darkMat,  0, 1.22,  0.3);   // operator floor
box(0.75,0.2, 0.7, seatMat,  0.15, 1.45, 0.35);
box(0.75,0.6, 0.1, seatMat,  0.15, 1.75, 0.02);

// Overhead guard pillars (create A-pillar blind spots)
const pillarMat = bodyMat;
box(0.1,1.6,0.1, pillarMat, -0.82,2.0, 1.0);   // front-left
box(0.1,1.6,0.1, pillarMat,  0.82,2.0, 1.0);   // front-right
box(0.1,1.6,0.1, pillarMat, -0.82,2.0,-0.45);  // rear-left
box(0.1,1.6,0.1, pillarMat,  0.82,2.0,-0.45);  // rear-right

// Guard top frame
box(1.8,0.08,0.08, pillarMat, 0,2.82, 1.0);
box(1.8,0.08,0.08, pillarMat, 0,2.82,-0.45);
box(0.08,0.08,1.55, pillarMat,-0.85,2.82,0.275);
box(0.08,0.08,1.55, pillarMat, 0.85,2.82,0.275);
box(1.8,0.06,0.06, pillarMat, 0,2.82,0.275);
box(0.06,0.06,1.55, pillarMat,0,2.82,0.275);

// Mast assembly
const mastGroup = new THREE.Group();
forkliftGroup.add(mastGroup);

const mastL = new THREE.Mesh(new THREE.BoxGeometry(0.15,3.5,0.2), mastMat);
mastL.position.set(-0.55,1.75,1.4); mastL.castShadow=true; mastGroup.add(mastL);
const mastR = new THREE.Mesh(new THREE.BoxGeometry(0.15,3.5,0.2), mastMat);
mastR.position.set( 0.55,1.75,1.4); mastR.castShadow=true; mastGroup.add(mastR);

for(let y of [0.5,1.5,2.5,3.2]) {
  const brace = new THREE.Mesh(new THREE.BoxGeometry(1.1,0.12,0.12), mastMat);
  brace.position.set(0,y,1.4); mastGroup.add(brace);
}

// Hydraulic cylinders
for(let x of [-0.25, 0.25]) {
  const hc = new THREE.Mesh(new THREE.CylinderGeometry(0.06,0.06,2.5,8), cylMat);
  hc.position.set(x,1.25,1.5); mastGroup.add(hc);
}

// Lift carriage + forks
const carriageGroup = new THREE.Group();
mastGroup.add(carriageGroup);

const carriage = new THREE.Mesh(new THREE.BoxGeometry(1.3,0.6,0.2), carMat);
carriage.position.set(0,0.5,1.55); carriage.castShadow=true; carriageGroup.add(carriage);

for(let x of [-0.35, 0.35]) {
  const fork = new THREE.Mesh(new THREE.BoxGeometry(0.12,0.1,1.8), forkMat);
  fork.position.set(x,0.2,2.45); fork.castShadow=true; carriageGroup.add(fork);
}

// Load cargo
const loadGroup = new THREE.Group();
const loadMat2 = new THREE.MeshStandardMaterial({ color: 0x8B6914, roughness: 0.9 });
for(let y of [0.5,1.3]) {
  const b = new THREE.Mesh(new THREE.BoxGeometry(1.1,0.8,1.1), loadMat2);
  b.position.set(0,y,0); loadGroup.add(b);
}
loadGroup.position.set(0,0.2,2.45);
loadGroup.visible = false;
carriageGroup.add(loadGroup);

// Wheels
function makeWheel(px, pz) {
  const wg = new THREE.Group();
  const tire = new THREE.Mesh(new THREE.CylinderGeometry(0.42,0.42,0.35,20), wheelMat);
  tire.rotation.z = Math.PI/2;
  const rim  = new THREE.Mesh(new THREE.CylinderGeometry(0.25,0.25,0.38,16), rimMat);
  rim.rotation.z = Math.PI/2;
  wg.add(tire); wg.add(rim);
  wg.position.set(px,0.42,pz);
  forkliftGroup.add(wg);
}
makeWheel(-1.05, 1.1); makeWheel(1.05, 1.1);
makeWheel(-1.0, -1.5); makeWheel(1.0, -1.5);

// Steering wheel
const swMat = new THREE.MeshStandardMaterial({ color: 0x222830, roughness: 0.8 });
const swGroup = new THREE.Group();
swGroup.add(new THREE.Mesh(new THREE.TorusGeometry(0.22,0.025,8,24), swMat));
swGroup.add(new THREE.Mesh(new THREE.CylinderGeometry(0.02,0.02,0.3,8), swMat));
swGroup.rotation.x = -Math.PI/4;
swGroup.position.set(-0.5,1.6,0.55);
forkliftGroup.add(swGroup);

// Headlights
for(let x of [-0.6, 0.6]) {
  const hl = new THREE.Mesh(new THREE.BoxGeometry(0.2,0.1,0.05), lightMat);
  hl.position.set(x,1.0,1.55); forkliftGroup.add(hl);
}

// Strobe beacon
const strobe = new THREE.Mesh(new THREE.CylinderGeometry(0.08,0.08,0.15,8), strobeMat);
strobe.position.set(0,2.92,0.275);
forkliftGroup.add(strobe);

// =============================================
// BLIND ZONE VOLUMES
// =============================================
const blindZones = new THREE.Group();
scene.add(blindZones);

function makeConeZone(color, opacity, rx, ry, rz, px, py, pz, rad, h) {
  const geo = new THREE.ConeGeometry(rad, h, 32, 1, true);
  const mat = new THREE.MeshBasicMaterial({ color, transparent:true, opacity, side:THREE.DoubleSide, depthWrite:false });
  const m = new THREE.Mesh(geo, mat);
  m.rotation.set(rx,ry,rz); m.position.set(px,py,pz);
  blindZones.add(m); return m;
}

function makeBoxZone(color, opacity, w, h, d, px, py, pz, ry=0) {
  const geo = new THREE.BoxGeometry(w,h,d);
  const mat = new THREE.MeshBasicMaterial({ color, transparent:true, opacity, side:THREE.DoubleSide, depthWrite:false });
  const m = new THREE.Mesh(geo, mat);
  m.position.set(px,py,pz); m.rotation.y = ry;
  blindZones.add(m); return m;
}

// Front mast
makeConeZone(0xff2200, 0.18,  Math.PI/2, 0, 0,  0, 0.8,  5.5, 1.8, 5.5);
makeBoxZone( 0xff3300, 0.15,  1.4, 3.5, 0.8,    0, 1.5,  3.0);
// Rear counterweight
makeConeZone(0xffaa00, 0.15, -Math.PI/2, 0, 0,  0, 0.8, -4.5, 1.5, 4.5);
// Left A-pillar
makeConeZone(0xff6600, 0.12, 0,0, Math.PI*0.42, -3.5, 1.5, 0.3, 1.2, 5.0);
// Right A-pillar
makeConeZone(0xff6600, 0.12, 0,0,-Math.PI*0.42,  3.5, 1.5, 0.3, 1.2, 5.0);
// Load zone (toggled)
const loadBlindZone = makeBoxZone(0xff4400, 0.20, 1.5, 3.0, 4.0, 0, 1.8, 4.5);
loadBlindZone.visible = false;

// Driver's visible cone
const visCone = new THREE.Mesh(
  new THREE.ConeGeometry(5, 8, 32, 1, true),
  new THREE.MeshBasicMaterial({ color:0x0088ff, transparent:true, opacity:0.04, side:THREE.DoubleSide, depthWrite:false })
);
visCone.rotation.x = Math.PI/2;
visCone.position.set(0.3,1.5,4.5);
scene.add(visCone);

// =============================================
// PEDESTRIAN FIGURE
// =============================================
const personGroup = new THREE.Group();
scene.add(personGroup);
personGroup.position.set(3,0,2);

const skinMat   = new THREE.MeshStandardMaterial({ color:0xf4c87a, roughness:0.8 });
const vestMat   = new THREE.MeshStandardMaterial({ color:0xff6600, roughness:0.7 });
const helmetMat = new THREE.MeshStandardMaterial({ color:0xffff00, roughness:0.5, metalness:0.3 });
const jeansMat  = new THREE.MeshStandardMaterial({ color:0x1a3a6a, roughness:0.8 });
const bootMat2  = new THREE.MeshStandardMaterial({ color:0x2a1a0a, roughness:0.9 });
const stripeMat3= new THREE.MeshStandardMaterial({ color:0xffff00, emissive:0xffff00, emissiveIntensity:0.3 });

function buildPerson() {
  // Boots
  for(let x of [-0.12, 0.12]) {
    const b = new THREE.Mesh(new THREE.BoxGeometry(0.18,0.15,0.28), bootMat2);
    b.position.set(x,0.075,0); personGroup.add(b);
    const leg = new THREE.Mesh(new THREE.CylinderGeometry(0.09,0.09,0.7,8), jeansMat);
    leg.position.set(x,0.52,0); personGroup.add(leg);
  }
  // Torso
  const torso = new THREE.Mesh(new THREE.BoxGeometry(0.4,0.55,0.25), vestMat);
  torso.position.set(0,1.15,0); personGroup.add(torso);
  // Hi-vis stripes
  for(let y of [1.05, 1.25]) {
    const s = new THREE.Mesh(new THREE.BoxGeometry(0.42,0.06,0.27), stripeMat3);
    s.position.set(0,y,0); personGroup.add(s);
  }
  // Arms
  for(let [x,rz] of [[-0.28, Math.PI/8],[0.28,-Math.PI/8]]) {
    const arm = new THREE.Mesh(new THREE.CylinderGeometry(0.07,0.07,0.5,8), vestMat);
    arm.rotation.z = rz; arm.position.set(x,1.1,0); personGroup.add(arm);
  }
  // Neck + Head
  const neck = new THREE.Mesh(new THREE.CylinderGeometry(0.07,0.07,0.15,8), skinMat);
  neck.position.set(0,1.5,0); personGroup.add(neck);
  const head = new THREE.Mesh(new THREE.SphereGeometry(0.18,12,10), skinMat);
  head.position.set(0,1.75,0); personGroup.add(head);
  // Hard hat
  const hat = new THREE.Mesh(new THREE.CylinderGeometry(0.02,0.22,0.08,16), helmetMat);
  hat.position.set(0,1.9,0); personGroup.add(hat);
  const hatTop = new THREE.Mesh(new THREE.SphereGeometry(0.2,12,6, 0,Math.PI*2, 0,Math.PI/2), helmetMat);
  hatTop.position.set(0,1.91,0); personGroup.add(hatTop);
  // Ground indicator ring
  const ring = new THREE.Mesh(
    new THREE.CircleGeometry(0.4,16),
    new THREE.MeshBasicMaterial({ color:0x00ff88, transparent:true, opacity:0.4 })
  );
  ring.rotation.x = -Math.PI/2; ring.position.y = 0.02;
  personGroup.add(ring);
}
buildPerson();

// =============================================
// BLIND ZONE DETECTION
// =============================================
function isInBlindZone(px, pz) {
  const inFrontMast    = (Math.abs(px) < 0.7) && (pz > 1.3) && (pz < 8.0);
  const inRear         = (Math.abs(px) < 1.0) && (pz < -1.8) && (pz > -7.0);
  const leftDist  = Math.sqrt((px+0.82)**2 + (pz-0.27)**2);
  const leftAngle = Math.atan2(pz-0.27, -(px+0.82));
  const inLeftPillar   = (leftDist>1.0)&&(leftDist<6.0)&&(Math.abs(leftAngle)<0.35);
  const rightDist = Math.sqrt((px-0.82)**2 + (pz-0.27)**2);
  const rightAngle= Math.atan2(pz-0.27, px-0.82);
  const inRightPillar  = (rightDist>1.0)&&(rightDist<6.0)&&(Math.abs(rightAngle)<0.35);
  const inLoad = loadGroup.visible && (Math.abs(px)<0.85)&&(pz>1.5)&&(pz<7.0);
  return inFrontMast || inRear || inLeftPillar || inRightPillar || inLoad;
}

// =============================================
// UI STATE
// =============================================
let showBlindZones = true;
let loadActive = false;
let personAnimActive = false;
let personAnimT = 0;
let personInDanger = false;
let alertTimeout = null;

const pxSlider   = document.getElementById('px');
const pzSlider   = document.getElementById('pz');
const forkHSlider= document.getElementById('forkH');

function updatePersonFromSliders() {
  const x = parseFloat(pxSlider.value);
  const z = parseFloat(pzSlider.value);
  document.getElementById('px-val').textContent = x.toFixed(1)+'m';
  document.getElementById('pz-val').textContent = z.toFixed(1)+'m';
  if (!personAnimActive) personGroup.position.set(x,0,z);
  updatePersonStatus();
}

function updateForkHeight() {
  const h = parseFloat(forkHSlider.value);
  document.getElementById('forkH-val').textContent = h.toFixed(1)+'m';
  carriageGroup.position.y = h;
  loadBlindZone.visible = loadActive && h > 0.8;
}

pxSlider.addEventListener('input', updatePersonFromSliders);
pzSlider.addEventListener('input', updatePersonFromSliders);
forkHSlider.addEventListener('input', updateForkHeight);

function updatePersonStatus() {
  const px = personGroup.position.x;
  const pz = personGroup.position.z;
  const danger = isInBlindZone(px, pz);
  if (danger !== personInDanger) {
    personInDanger = danger;
    const ring = personGroup.children[personGroup.children.length-1];
    if (ring && ring.material) ring.material.color.set(danger ? 0xff2244 : 0x00ff88);
    const statusEl = document.getElementById('person-status');
    statusEl.textContent = danger ? '⚠ DANGER!' : 'SAFE';
    statusEl.className = 'stat-value ' + (danger ? 'danger' : 'safe');
    const alertEl = document.getElementById('alert');
    if (danger) {
      alertEl.classList.add('show');
      if (alertTimeout) clearTimeout(alertTimeout);
      alertTimeout = setTimeout(() => alertEl.classList.remove('show'), 3000);
    }
  }
}

// =============================================
// VIEW CONTROLS
// =============================================
function setView(v) {
  document.querySelectorAll('.ctrl-btn').forEach(b => b.classList.remove('active'));
  currentView = v;
  switch(v) {
    case 'orbit':
      document.getElementById('btn-orbit').classList.add('active');
      document.getElementById('view-mode-txt').textContent = 'Free Rotate';
      lerpingCam = false;
      camera.position.set(8,6,10);
      camera.lookAt(0,1,0);
      break;
    case 'driver':
      document.getElementById('btn-driver').classList.add('active');
      document.getElementById('view-mode-txt').textContent = 'Driver POV (1st person)';
      lerpingCam = true;
      targetCamPos.set(0.15,2.55,0.35);
      targetCamLook.set(0,1.8,8);
      break;
    case 'top':
      document.getElementById('btn-top').classList.add('active');
      document.getElementById('view-mode-txt').textContent = 'Top View (Bird\'s Eye)';
      lerpingCam = true;
      targetCamPos.set(0,14,0.5);
      targetCamLook.set(0,0,0.5);
      break;
    case 'side':
      document.getElementById('btn-side').classList.add('active');
      document.getElementById('view-mode-txt').textContent = 'Side View';
      lerpingCam = true;
      targetCamPos.set(-10,3,0);
      targetCamLook.set(0,1,0);
      break;
  }
}

function toggleBlind() {
  showBlindZones = !showBlindZones;
  blindZones.visible = showBlindZones;
  visCone.visible = showBlindZones;
  document.getElementById('btn-blind').classList.toggle('active', showBlindZones);
}

function toggleLoad() {
  loadActive = !loadActive;
  loadGroup.visible = loadActive;
  const fh = parseFloat(forkHSlider.value);
  loadBlindZone.visible = loadActive && fh > 0.8;
  document.getElementById('btn-load').classList.toggle('active', loadActive);
  document.getElementById('blind-pct').textContent = loadActive ? '45%' : '27%';
  document.getElementById('vis-pct').textContent   = loadActive ? '55%' : '73%';
}

function toggleAnim() {
  personAnimActive = !personAnimActive;
  document.getElementById('btn-anim').classList.toggle('active', personAnimActive);
  document.getElementById('btn-anim').textContent = personAnimActive ? '⏸ PAUSE' : '▶ WALK PEDESTRIAN';
}

// =============================================
// ORBIT MOUSE / TOUCH CONTROLS
// =============================================
renderer.domElement.addEventListener('mousedown', e => {
  if(currentView!=='orbit') return;
  isDragging=true; lastMX=e.clientX; lastMY=e.clientY;
});
renderer.domElement.addEventListener('mousemove', e => {
  if(!isDragging||currentView!=='orbit') return;
  orbitTheta -= (e.clientX-lastMX)*0.008;
  orbitPhi = Math.max(0.05, Math.min(Math.PI/2-0.05, orbitPhi-(e.clientY-lastMY)*0.006));
  lastMX=e.clientX; lastMY=e.clientY;
});
renderer.domElement.addEventListener('mouseup',   () => isDragging=false);
renderer.domElement.addEventListener('mouseleave',() => isDragging=false);
renderer.domElement.addEventListener('wheel', e => {
  if(currentView!=='orbit') return;
  orbitR = Math.max(3, Math.min(30, orbitR+e.deltaY*0.02));
});

let lastTouchDist=0;
renderer.domElement.addEventListener('touchstart', e=>{
  if(e.touches.length===1&&currentView==='orbit'){isDragging=true;lastMX=e.touches[0].clientX;lastMY=e.touches[0].clientY;}
  if(e.touches.length===2) lastTouchDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
});
renderer.domElement.addEventListener('touchmove', e=>{
  if(e.touches.length===1&&isDragging&&currentView==='orbit'){
    orbitTheta-=(e.touches[0].clientX-lastMX)*0.01;
    orbitPhi=Math.max(0.05,Math.min(Math.PI/2-0.05,orbitPhi-(e.touches[0].clientY-lastMY)*0.008));
    lastMX=e.touches[0].clientX;lastMY=e.touches[0].clientY;
  }
  if(e.touches.length===2){const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);orbitR=Math.max(3,Math.min(30,orbitR-(d-lastTouchDist)*0.05));lastTouchDist=d;}
  e.preventDefault();
},{passive:false});
renderer.domElement.addEventListener('touchend',()=>isDragging=false);

// =============================================
// ANIMATION LOOP
// =============================================
const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();

  // Orbit camera
  if(currentView==='orbit'){
    const x = orbitR*Math.sin(orbitPhi)*Math.sin(orbitTheta);
    const y = orbitR*Math.cos(orbitPhi);
    const z = orbitR*Math.sin(orbitPhi)*Math.cos(orbitTheta);
    camera.position.set(x+orbitTarget.x, y+orbitTarget.y, z+orbitTarget.z);
    camera.lookAt(orbitTarget);
  }

  // Smooth camera transitions
  if(lerpingCam && currentView!=='orbit'){
    camera.position.lerp(targetCamPos, 0.06);
    const curDir = new THREE.Vector3();
    camera.getWorldDirection(curDir);
    const desDir = targetCamLook.clone().sub(camera.position).normalize();
    camera.lookAt(camera.position.clone().add(curDir.lerp(desDir,0.06).normalize()));
  }

  // Strobe animation
  strobe.material.emissiveIntensity = 0.5+0.5*Math.sin(t*4);
  warningLight.intensity = 0.3+0.3*Math.sin(t*4);

  // Pedestrian walk animation
  if(personAnimActive){
    personAnimT += 0.012;
    const radius = 3.5+Math.sin(personAnimT*0.3)*1.5;
    const px = Math.cos(personAnimT)*radius;
    const pz = Math.sin(personAnimT)*radius;
    personGroup.position.set(px,0,pz);
    personGroup.rotation.y = -personAnimT-Math.PI/2;
    pxSlider.value = px.toFixed(1);
    pzSlider.value = pz.toFixed(1);
    document.getElementById('px-val').textContent = px.toFixed(1)+'m';
    document.getElementById('pz-val').textContent = pz.toFixed(1)+'m';
  }

  updatePersonStatus();
  renderer.render(scene, camera);
}

animate();

window.addEventListener('resize', () => {
  const W=window.innerWidth, H=window.innerHeight;
  camera.aspect=W/H; camera.updateProjectionMatrix();
  renderer.setSize(W,H);
});

// Init
updatePersonFromSliders();
updateForkHeight();
setView('orbit');
</script>
